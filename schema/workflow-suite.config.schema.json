{
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "modules": {
      "type": "object",
      "properties": {
        "notifier": {
          "type": "boolean"
        },
        "repoLocal": {
          "type": "boolean"
        },
        "todoEnforcer": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "notifier": {
      "type": "object",
      "properties": {
        "command": {
          "type": "object",
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "cooldownMs": {
          "type": "integer",
          "minimum": 0
        },
        "enabled": {
          "type": "boolean"
        },
        "events": {
          "type": "object",
          "properties": {
            "enforcerFailure": {
              "type": "boolean"
            },
            "error": {
              "type": "boolean"
            },
            "paused": {
              "type": "boolean"
            },
            "permission": {
              "type": "boolean"
            },
            "question": {
              "type": "boolean"
            },
            "terminalReady": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "focusCommand": {
          "type": "object",
          "properties": {
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "focusTitleHints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maxWaitMs": {
          "type": "integer",
          "minimum": 0
        },
        "pollMs": {
          "type": "integer",
          "minimum": 0
        },
        "quietHours": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "end": {
              "type": "string",
              "pattern": "^\\d{2}:\\d{2}$"
            },
            "start": {
              "type": "string",
              "pattern": "^\\d{2}:\\d{2}$"
            }
          },
          "additionalProperties": false
        },
        "settleMs": {
          "type": "integer",
          "minimum": 0
        },
        "showToastFallback": {
          "type": "boolean"
        },
        "suppressWhenFocused": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "todoEnforcer": {
      "type": "object",
      "properties": {
        "abortWindowMs": {
          "type": "integer",
          "minimum": 0
        },
        "countdownGraceMs": {
          "type": "integer",
          "minimum": 0
        },
        "countdownMs": {
          "type": "integer",
          "minimum": 0
        },
        "continuationCooldownMs": {
          "type": "integer",
          "minimum": 0
        },
        "debug": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "failureResetWindowMs": {
          "type": "integer",
          "minimum": 0
        },
        "guards": {
          "type": "object",
          "properties": {
            "abortWindow": {
              "type": "boolean"
            },
            "backgroundTasks": {
              "type": "boolean"
            },
            "skippedAgents": {
              "type": "boolean"
            },
            "stopState": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "maxConsecutiveFailures": {
          "type": "integer",
          "exclusiveMinimum": true,
          "minimum": 0
        },
        "prompt": {
          "type": "string"
        },
        "sessionPruneIntervalMs": {
          "type": "integer",
          "minimum": 0
        },
        "sessionTtlMs": {
          "type": "integer",
          "minimum": 0
        },
        "skipAgents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stopCommand": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$id": "https://unpkg.com/opencode-workflow-suite/schema/workflow-suite.config.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenCode Workflow Suite Config"
}
